# Copy to .env and replace YOUR_PASSWORD with your Supabase database password.
# URL-encode special characters in passwords: [ → %5B  ] → %5D  @ → %40

# Transaction pooler for app runtime (port 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler for Prisma migrations (port 5432, same pooler host)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase client (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Supabase Database Webhook → /api/webhooks/supabase/loyalty
SUPABASE_WEBHOOK_SECRET="generate-a-long-random-secret"

# Phase 2 — Apple Wallet (Pass Type ID + certificates)
# PASSKIT_PASS_TYPE_ID=
# PASSKIT_TEAM_ID=
# PASSKIT_CERT_PEM=
# PASSKIT_KEY_PEM=
# PASSKIT_KEY_PASSPHRASE=

# Phase 2 — Google Wallet (service account)
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
